PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Abstract API (real SMTP mailbox check) ────────────────────────────────────
# Free plan: 100 req/month, no credit card needed.
# Sign up → https://www.abstractapi.com/api/email-validation-verification-api
# On Render: Dashboard → Service → Environment → Add Variable
# If ABSENT, the server falls back to local MX + raw SMTP (may show
# "smtp_unavailable" on cloud hosts where port 25/587 is blocked).
ABSTRACT_API_KEY=your_key_here
